# ===========================================
# CLÍNICA HISPANA CRUZ 4 - Variables de entorno
# ===========================================

# Resend (emails del formulario de contacto). API key en https://resend.com
# Requiere verificar el dominio en Resend para que funcione noreply@dominio.
RESEND_API_KEY=

# Google Places API (reviews reales en testimonials/JSON-LD).
# NOTA: el código usa la Places API "legacy" (maps.googleapis.com/maps/api/place).
# Habilitar esa API + billing en Google Cloud y restringir la key.
GOOGLE_PLACES_API_KEY=
# Place ID REAL de Cruz 4 — verificar antes de pegar (Place ID Finder / Text Search).
GOOGLE_PLACE_ID=

# Google Maps Embed API (opcional, para el mapa de ubicación)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Site URL (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.clinicahispanacruz4.com

# Google Analytics 4 (Measurement ID, formato G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Ads (formato AW-#########)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Meta Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversions API (opcional, dedup server-side)
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
